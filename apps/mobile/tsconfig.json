{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@metatune/common": [
                "../../packages/common/src"
            ],
            "@metatune/common/*": [
                "../../packages/common/src/*"
            ]
        },
        "types": ["@dcloudio/types"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "src/**/*.d.ts"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}